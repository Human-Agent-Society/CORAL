#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;

    // Read all polyominoes
    struct Poly {
        int k;
        vector<pair<int,int>> cells;
    };
    vector<Poly> polys(n);
    int totalCells = 0;

    for (int i = 0; i < n; i++) {
        cin >> polys[i].k;
        polys[i].cells.resize(polys[i].k);
        for (int j = 0; j < polys[i].k; j++) {
            cin >> polys[i].cells[j].first >> polys[i].cells[j].second;
        }
        totalCells += polys[i].k;
    }

    // Normalize each polyomino: shift so min coords are (0,0)
    // Try all 8 orientations (4 rotations x 2 reflections), pick the one
    // with smallest bounding box height then width
    struct Placement {
        vector<pair<int,int>> cells;
        int w, h;
        int rot, flip;
    };

    auto transform = [](const vector<pair<int,int>>& cells, int rot, int flip) {
        vector<pair<int,int>> res;
        for (auto [x, y] : cells) {
            int nx = x, ny = y;
            // Flip first (reflect across y-axis)
            if (flip) nx = -nx;
            // Rotate clockwise rot times
            for (int r = 0; r < rot; r++) {
                int tmp = nx;
                nx = ny;
                ny = -tmp;
            }
            res.push_back({nx, ny});
        }
        // Normalize
        int minx = INT_MAX, miny = INT_MAX;
        for (auto [x, y] : res) { minx = min(minx, x); miny = min(miny, y); }
        for (auto& [x, y] : res) { x -= minx; y -= miny; }
        return res;
    };

    // For each poly, find best orientation (smallest h, then w)
    // and store the chosen orientation
    vector<Placement> best(n);
    for (int i = 0; i < n; i++) {
        best[i].w = INT_MAX;
        best[i].h = INT_MAX;
        for (int f = 0; f < 2; f++) {
            for (int r = 0; r < 4; r++) {
                auto cells = transform(polys[i].cells, r, f);
                int mx = 0, my = 0;
                for (auto [x, y] : cells) { mx = max(mx, x); my = max(my, y); }
                int w = mx + 1, h = my + 1;
                // Prefer orientations that are wide and short (good for row packing)
                if (h < best[i].h || (h == best[i].h && w < best[i].w)) {
                    best[i] = {cells, w, h, r, f};
                }
            }
        }
    }

    // Sort polyominoes by height descending, then width descending (FFDH-like)
    vector<int> order(n);
    iota(order.begin(), order.end(), 0);
    sort(order.begin(), order.end(), [&](int a, int b) {
        if (best[a].h != best[b].h) return best[a].h > best[b].h;
        return best[a].w > best[b].w;
    });

    // Grid size: start with ceil(sqrt(totalCells)) and expand if needed
    int S = max(1, (int)ceil(sqrt((double)totalCells * 1.3)));

    // Simple greedy placement: use a grid, place each piece at the first
    // position where it fits (scan row by row, left to right)
    vector<vector<bool>> grid;
    vector<int> tx(n), ty(n);

    auto tryPlace = [&](int S) -> bool {
        grid.assign(S, vector<bool>(S, false));
        for (int idx : order) {
            auto& p = best[idx];
            bool placed = false;
            for (int y = 0; y <= S - p.h && !placed; y++) {
                for (int x = 0; x <= S - p.w && !placed; x++) {
                    // Check if all cells are free
                    bool ok = true;
                    for (auto [cx, cy] : p.cells) {
                        if (grid[y + cy][x + cx]) { ok = false; break; }
                    }
                    if (ok) {
                        // Place it
                        for (auto [cx, cy] : p.cells) {
                            grid[y + cy][x + cx] = true;
                        }
                        tx[idx] = x;
                        ty[idx] = y;
                        placed = true;
                    }
                }
            }
            if (!placed) return false;
        }
        return true;
    };

    // Try increasing sizes until it fits
    while (!tryPlace(S)) {
        S++;
    }

    // Output: W H (the problem says W=H for square)
    cout << S << " " << S << "\n";
    for (int i = 0; i < n; i++) {
        cout << tx[i] << " " << ty[i] << " " << best[i].rot << " " << best[i].flip << "\n";
    }

    return 0;
}
